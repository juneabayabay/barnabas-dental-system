SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — local dev (individual vars)
DB_NAME=database_db
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# Production (Aiven / Render): use DATABASE_URL OR DB_* vars — not both required.
# DATABASE_URL=postgres://user:password@host:port/dbname?sslmode=require
# DB_SSL_REQUIRE=True
# DB_SSLMODE=require

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
# Production: CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app
# (defaults to CORS_ALLOWED_ORIGINS when unset)

TIME_ZONE=Asia/Manila
FRONTEND_URL=http://localhost:5173

# Email — leave EMAIL_HOST_USER empty to use console backend (prints to runserver terminal).
# Gmail: enable 2-Step Verification, create an App Password, then set:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=youraccount@gmail.com
# EMAIL_HOST_PASSWORD=your-16-char-app-password
# DEFAULT_FROM_EMAIL=youraccount@gmail.com

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Production HTTPS (Render terminates TLS at the edge; keep SECURE_SSL_REDIRECT=False)
# SECURE_SSL_REDIRECT=False
# SECURE_HSTS_SECONDS=31536000
